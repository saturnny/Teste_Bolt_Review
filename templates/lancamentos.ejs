<%- include('header_bootstrap', {title: 'Meus Lançamentos'}) %>

<div class="topbar">
    <div class="topbar-title">
        <h1>Meus Lançamentos</h1>
        <p>Gerencie todos os seus lançamentos de atividades</p>
    </div>
</div>
<div class="row">
<!-- Filtro de Data -->
<div class="card mb-4">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
            <div class="d-flex align-items-center gap-3">
                <label for="filtro-data" class="form-label mb-0 fw-bold">
                    <i class="bi bi-calendar3 me-2"></i>Filtrar por Data:
                </label>
                <input type="date" id="filtro-data" class="form-control" style="width: 200px;">
                <button class="btn btn-outline-secondary" onclick="limparFiltro()">
                    <i class="bi bi-x-circle me-1"></i>Limpar Filtro
                </button>
            </div>
            <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#newLancamentoModal">
                <i class="bi bi-plus-circle me-1"></i>Novo Lançamento
            </button>
        </div>
    </div>
</div>

<!-- Estatísticas -->
<div class="stats-grid mb-4">
    <div class="stat-card primary">
        <div class="stat-icon">
            <i class="bi bi-clipboard-data"></i>
        </div>
        <div class="stat-content">
            <div class="stat-value" id="total-lancamentos"><%= typeof lancamentos !== 'undefined' ? lancamentos.length : 0 %></div>
            <div class="stat-label">Total de Lançamentos</div>
        </div>
    </div>
    
    <div class="stat-card success">
        <div class="stat-icon">
            <i class="bi bi-clock"></i>
        </div>
        <div class="stat-content">
            <div class="stat-value" id="total-horas">
                <% if (typeof totalGeralHorasTrabalhadas !== 'undefined') { %>
                    <% 
                        const hours = Math.floor(parseFloat(totalGeralHorasTrabalhadas));
                        const minutes = Math.round((parseFloat(totalGeralHorasTrabalhadas) - hours) * 60);
                    %>
                    <%= hours %>h <%= minutes %>m
                <% } else { %>
                    0h 0m
                <% } %>
            </div>
            <div class="stat-label">Horas Totais</div>
        </div>
    </div>
    
    <div class="stat-card info">
        <div class="stat-icon">
            <i class="bi bi-clock-history"></i>
        </div>
        <div class="stat-content">
            <div class="stat-value" id="horas-pendentes">
                <% if (typeof totalHorasPendentes !== 'undefined') { %>
                    <% 
                        const hours = Math.floor(parseFloat(totalHorasPendentes));
                        const minutes = Math.round((parseFloat(totalHorasPendentes) - hours) * 60);
                    %>
                    <%= hours %>h <%= minutes %>m
                <% } else { %>
                    0h 0m
                <% } %>
            </div>
            <div class="stat-label">Horas Pendentes</div>
        </div>
    </div>
</div>

<!-- Tabela de Lançamentos -->
<div class="card">
    <div class="card-header">
        <h2 class="card-title">
            <i class="bi bi-list-ul me-2"></i>
            Todos os Lançamentos
        </h2>
        <p class="card-description">Visualize e gerencie todos os seus lançamentos</p>
    </div>

    <% if (typeof lancamentos !== 'undefined' && lancamentos.length > 0) { %>
    <div class="table-responsive">
        <table class="table table-hover align-middle" id="tabela-lancamentos">
            <thead>
                <tr>
                    <th><i class="bi bi-calendar3 me-1"></i>Data</th>
                    <th><i class="bi bi-clock me-1"></i>Início</th>
                    <th><i class="bi bi-clock-fill me-1"></i>Fim</th>
                    <th><i class="bi bi-list-task me-1"></i>Atividade</th>
                    <th><i class="bi bi-hourglass-split me-1"></i>Duração</th>
                    <th style="width: 120px;"><i class="bi bi-gear me-1"></i>Ações</th>
                </tr>
            </thead>
            <tbody>
                <% lancamentos.forEach(function(lancamento) { %>
                <tr data-data="<%= (lancamento.data) ? new Date(lancamento.data).toISOString().split('T')[0] : '' %>">
                    <td>
                        <span class="badge bg-light text-dark"><%= (lancamento.data) ? new Date(lancamento.data).toLocaleDateString('pt-BR') : '-' %></span>
                    </td>
                    <td><%= lancamento.hora_inicio %></td>
                    <td><%= lancamento.hora_fim %></td>
                    <td>
                        <div class="d-flex align-items-center gap-2">
                            <span class="badge bg-primary"><%= (lancamento.Atividade) ? lancamento.Atividade.nome : (lancamento.atividade ? lancamento.atividade.nome : '-') %></span>
                            <small class="text-muted"><%= (lancamento.Atividade && lancamento.Atividade.Categoria) ? lancamento.Atividade.Categoria.nome : (lancamento.atividade && lancamento.atividade.categoria ? lancamento.atividade.categoria.nome : '-') %></small>
                        </div>
                    </td>
                    <td>
                        <span class="badge bg-success"><%= parseFloat(lancamento.horas_trabalhadas || 0).toFixed(1) %>h</span>
                    </td>
                    <td>
                        <div class="btn-group" role="group">
                            <button class="btn btn-sm btn-outline-primary edit-btn-caneta" 
                                   data-bs-toggle="tooltip" 
                                   data-bs-placement="top" 
                                   title="Editar lançamento"
                                   data-id="<%= lancamento.id %>"
                                   data-data="<%= (lancamento.data) ? new Date(lancamento.data).toISOString().split('T')[0] : '' %>"
                                   data-inicio="<%= lancamento.hora_inicio %>"
                                   data-fim="<%= lancamento.hora_fim %>"
                                   data-atividade="<%= (lancamento.Atividade) ? lancamento.Atividade.id : (lancamento.atividade ? lancamento.atividade.id : '') %>"
                                   data-observacao="<%= lancamento.descricao || '' %>"
                                   onclick="openEditModal('<%= lancamento.id %>')">
                                <i class="bi bi-pencil"></i>
                            </button>
                            <button class="btn btn-sm btn-outline-danger delete-btn-caneta" 
                                    data-bs-toggle="tooltip" 
                                    data-bs-placement="top" 
                                    title="Excluir lançamento"
                                    data-id="<%= lancamento.id %>"
                                   onclick="deleteLancamento('<%= lancamento.id %>')">
                                <i class="bi bi-trash"></i>
                            </button>
                        </div>
                    </td>
                </tr>
                <% }); %>
            </tbody>
        </table>
    </div>
    <% } else { %>
    <div class="card-body text-center py-5">
        <div class="empty-state">
            <div class="empty-state-icon">
                <i class="bi bi-clipboard-x" style="font-size: 48px; color: var(--bs-secondary);"></i>
            </div>
            <div class="empty-state-title">Nenhum lançamento encontrado</div>
            <div class="empty-state-description">
                Você ainda não possui lançamentos de atividades registrados.
            </div>
            <% if (user.tipo_usuario !== "Admin") { %>
            <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#newLancamentoModal">
                <i class="bi bi-plus-circle me-1"></i>
                Adicionar Primeira Atividade
            </button>
            <% } %>
        </div>
    </div>
    <% } %>
</div>

<!-- Modal Novo Lançamento -->
<div class="modal fade" id="newLancamentoModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="bi bi-plus-circle me-2"></i>
                    Novo Lançamento
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            
            <form id="newLancamentoForm" method="post" action="/novo-lancamento" class="needs-validation" novalidate>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label for="modal_data" class="form-label">
                                <i class="bi bi-calendar3 me-1"></i>Data
                            </label>
                            <input type="date" id="modal_data" name="data" class="form-control" required>
                            <div class="invalid-feedback">
                                Por favor, selecione uma data.
                            </div>
                        </div>

                        <div class="col-md-4">
                            <label for="modal_hora_inicio" class="form-label">
                                <i class="bi bi-clock me-1"></i>Hora Início
                            </label>
                            <input type="text" id="modal_hora_inicio" name="hora_inicio" class="form-control time-picker-input" 
                                   placeholder="Selecione" readonly required>
                            <div class="invalid-feedback">
                                Por favor, informe a hora de início.
                            </div>
                        </div>

                        <div class="col-md-4">
                            <label for="modal_hora_fim" class="form-label">
                                <i class="bi bi-clock-fill me-1"></i>Hora Fim
                            </label>
                            <input type="text" id="modal_hora_fim" name="hora_fim" class="form-control time-picker-input" 
                                   placeholder="Selecione" readonly required>
                            <div class="invalid-feedback">
                                Por favor, informe a hora de término.
                            </div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="modal_atividade_id" class="form-label">
                            <i class="bi bi-list-task me-1"></i>Atividade
                        </label>
                        <select id="modal_atividade_id" name="atividade_id" class="form-select" required>
                            <option value="">Selecione uma atividade</option>
                            <% if (typeof atividades !== 'undefined') { %>
                                <% atividades.forEach(function(atividade) { %>
                            <option value="<%= atividade.id %>">
                                <%= atividade.nome %> (<%= (atividade.Categoria) ? atividade.Categoria.nome : (atividade.categoria ? atividade.categoria.nome : '-') %>)
                            </option>
                                <% }); %>
                            <% } %>
                        </select>
                        <div class="invalid-feedback">
                            Por favor, selecione uma atividade.
                        </div>
                    </div>

                    <div class="mb-4">
                        <label for="modal_observacao" class="form-label">
                            <i class="bi bi-chat-text me-1"></i>Observação
                        </label>
                        <textarea id="modal_observacao" name="observacao" class="form-control" rows="3" 
                                  placeholder="Adicione uma observação sobre esta atividade (opcional)"></textarea>
                    </div>

                    <!-- Duration Display -->
                    <div class="alert alert-info d-flex align-items-center" role="alert">
                        <i class="bi bi-hourglass-split me-2"></i>
                        <div id="modal_duration-display">
                            <strong>Duração Calculada:</strong>
                            <span class="badge bg-secondary">--</span>
                        </div>
                    </div>
                </div>
                
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
                        <i class="bi bi-x-circle me-1"></i>
                        Cancelar
                    </button>
                    <button type="button" class="btn btn-outline-secondary me-2" onclick="clearModalForm()">
                        <i class="bi bi-arrow-clockwise me-1"></i>
                        Limpar
                    </button>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-circle me-1"></i>
                        Salvar Lançamento
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal Confirmação Exclusão -->
<div class="modal fade" id="deleteConfirmModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title">
                    <i class="bi bi-exclamation-triangle me-2"></i>
                    Confirmar Exclusão
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="d-flex align-items-center mb-3">
                    <div class="me-3">
                        <i class="bi bi-trash text-danger" style="font-size: 2.5rem;"></i>
                    </div>
                    <div>
                        <h6 class="mb-2">Tem certeza que deseja excluir este lançamento?</h6>
                        <p class="text-muted mb-0">Esta ação não poderá ser desfeita.</p>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
                    <i class="bi bi-x-circle me-1"></i>
                    Cancelar
                </button>
                <button type="button" class="btn btn-danger" id="confirmDeleteBtn">
                    <i class="bi bi-trash me-1"></i>
                    Sim, Excluir
                </button>
            </div>
        </div>
    </div>
</div>
</div>
<%- include('footer_bootstrap') %>


