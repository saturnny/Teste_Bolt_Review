<script src="/static/js/notifications.js"></script>
<script>
// Filtro de data
function filtrarPorData() {
    const dataSelecionada = document.getElementById('filtro-data').value;
    const linhas = document.querySelectorAll('#tabela-lancamentos tbody tr');
    
    let totalLancamentos = 0;
    let totalHoras = 0;
    let diasUnicos = new Set();
    
    linhas.forEach(linha => {
        const dataAttr = linha.getAttribute('data-data');
        
        if (!dataSelecionada || dataAttr === dataSelecionada) {
            linha.style.display = '';
            totalLancamentos++;
            
            // Calcular horas
            const duracaoBadge = linha.querySelector('.badge.bg-success');
            if (duracaoBadge) {
                const horas = parseFloat(duracaoBadge.textContent.replace('h', ''));
                totalHoras += horas;
            }
            
            // Contar dias únicos
            diasUnicos.add(dataAttr);
        } else {
            linha.style.display = 'none';
        }
    });
    
    // Calcular meta de horas baseado nos dias únicos (9 horas por dia)
    const quantidadeDias = diasUnicos.size;
    const metaHoras = quantidadeDias > 0 ? quantidadeDias * 9.0 : 9.0;
    const horasPendentes = Math.max(0, metaHoras - totalHoras);
    
    // Atualizar estatísticas
    document.getElementById('total-lancamentos').textContent = totalLancamentos;
    document.getElementById('total-horas').textContent = totalHoras.toFixed(1);
    document.getElementById('horas-pendentes').textContent = horasPendentes.toFixed(1);
}

function limparFiltro() {
    document.getElementById('filtro-data').value = '';
    filtrarPorData();
}

// Função para validar sobreposição de horários
function validarSobreposicaoHorarios(lancamentoIdAtual = null) {
    const dataSelecionada = document.getElementById('modal_data').value;
    const horaInicio = document.getElementById('modal_hora_inicio').value;
    const horaFim = document.getElementById('modal_hora_fim').value;
    
    if (!dataSelecionada || !horaInicio || !horaFim) {
        return { valido: true }; // Deixa o validation padrão do HTML cuidar
    }
    
    // Converter horários para minutos para comparação
    const [inicioHoras, inicioMinutos] = horaInicio.split(':').map(Number);
    const [fimHoras, fimMinutos] = horaFim.split(':').map(Number);
    const novoInicio = inicioHoras * 60 + inicioMinutos;
    const novoFim = fimHoras * 60 + fimMinutos;
    
    // Verificar se hora fim é maior que hora início
    if (novoFim <= novoInicio) {
        return { 
            valido: false, 
            mensagem: 'A hora de término deve ser maior que a hora de início.' 
        };
    }
    
    // Verificar sobreposição com lançamentos existentes do mesmo dia
    const linhas = document.querySelectorAll('#tabela-lancamentos tbody tr');
    
    for (const linha of linhas) {
        const dataAttr = linha.getAttribute('data-data');
        
        // Verificar se é do mesmo dia
        if (dataAttr === dataSelecionada) {
            // Ignorar o lançamento sendo editado
            const editBtn = linha.querySelector('button[data-id]');
            const lancamentoId = editBtn ? editBtn.getAttribute('data-id') : null;
            
            if (lancamentoIdAtual && lancamentoId === lancamentoIdAtual) {
                continue; // Pula este lançamento (é o que está sendo editado)
            }
            
            const inicioExistente = linha.querySelector('td:nth-child(2)').textContent.trim();
            const fimExistente = linha.querySelector('td:nth-child(3)').textContent.trim();
            
            const [exInicioHoras, exInicioMinutos] = inicioExistente.split(':').map(Number);
            const [exFimHoras, exFimMinutos] = fimExistente.split(':').map(Number);
            
            const exInicio = exInicioHoras * 60 + exInicioMinutos;
            const exFim = exFimHoras * 60 + exFimMinutos;
            
            // Verificar sobreposição (exceto quando o novo início é igual ao fim do existente)
            // Sobreposição ocorre quando:
            // - novo início está entre início e fim do existente (exceto igual ao fim)
            // - novo fim está entre início e fim do existente (exceto igual ao início)
            // - novo período engloba completamente o período existente
            const haSobreposicao = (
                (novoInicio >= exInicio && novoInicio < exFim) || // início dentro do período
                (novoFim > exInicio && novoFim <= exFim) ||       // fim dentro do período
                (novoInicio <= exInicio && novoFim >= exFim)      // engloba o período
            );
            
            // Verificar se é permitido (início do novo = fim do existente)
            const permitido = (novoInicio === exFim);
            
            if (haSobreposicao && !permitido) {
                return {
                    valido: false,
                    mensagem: `Conflito de horário: Já existe um lançamento das ${inicioExistente} às ${fimExistente} neste dia. Um novo lançamento só pode começar às ${fimExistente} ou depois.`
                };
            }
        }
    }
    
    return { valido: true };
}

// Event listener para o filtro
document.getElementById('filtro-data')?.addEventListener('change', filtrarPorData);

// Calcular e exibir duração
function calculateDuration() {
    const inicio = document.getElementById('modal_hora_inicio').value;
    const fim = document.getElementById('modal_hora_fim').value;
    const durationDisplay = document.getElementById('modal_duration-display');
    
    if (inicio && fim) {
        const [inicioHoras, inicioMinutos] = inicio.split(':').map(Number);
        const [fimHoras, fimMinutos] = fim.split(':').map(Number);
        
        const inicioTotal = inicioHoras * 60 + inicioMinutos;
        const fimTotal = fimHoras * 60 + fimMinutos;
        
        if (fimTotal > inicioTotal) {
            const diff = fimTotal - inicioTotal;
            const horas = Math.floor(diff / 60);
            const minutos = diff % 60;
            const duracao = horas + (minutos / 60);
            
            durationDisplay.innerHTML = `<strong>Duração Calculada:</strong> <span class="badge bg-success">${horas}h${minutos > 0 ? minutos + 'min' : ''} (${duracao.toFixed(1)}h)</span>`;
        } else {
            durationDisplay.innerHTML = '<strong>Duração Calculada:</strong> <span class="badge bg-warning">Hora fim deve ser maior</span>';
        }
    } else {
        durationDisplay.innerHTML = '<strong>Duração Calculada:</strong> <span class="badge bg-secondary">--</span>';
    }
}

// Clear modal form
function clearModalForm() {
    document.getElementById('modal_hora_inicio').value = '';
    document.getElementById('modal_hora_fim').value = '';
    document.getElementById('modal_atividade_id').value = '';
    document.getElementById('modal_observacao').value = '';
    document.getElementById('modal_duration-display').innerHTML = '<strong>Duração Calculada:</strong> <span class="badge bg-secondary">--</span>';
}

// Time picker simplificado
class SimpleTimePicker {
    constructor(inputId) {
        this.input = document.getElementById(inputId);
        this.isOpen = false;
        this.selectedHour = null;
        this.selectedMinute = null;
        this.init();
    }

    init() {
        this.createPicker();
        this.attachEvents();
    }

    createPicker() {
        this.picker = document.createElement('div');
        this.picker.className = 'simple-time-picker';
        this.picker.style.cssText = `
            position: absolute;
            background: white;
            border: 1px solid #dee2e6;
            border-radius: 8px;
            box-shadow: 0 8px 32px rgba(0,0,0,0.15);
            padding: 16px;
            z-index: 9999;
            min-width: 280px;
            display: none;
        `;
        
        this.picker.innerHTML = `
            <div class="d-flex justify-content-between align-items-center mb-3">
                <strong>Selecionar Horário</strong>
                <button type="button" class="btn-close" onclick="this.closest('.simple-time-picker').style.display='none'"></button>
            </div>
            <div class="mb-3">
                <label class="form-label small">Horas (7-16):</label>
                <div class="d-flex flex-wrap gap-2">
                    ${Array.from({length: 10}, (_, i) => i + 7).map(h => 
                        `<button type="button" class="btn btn-sm btn-outline-secondary hour-btn" data-hour="${h}" style="width: 50px;">${h.toString().padStart(2,'0')}</button>`
                    ).join('')}
                </div>
            </div>
            <div class="mb-3">
                <label class="form-label small">Minutos:</label>
                <div class="d-flex gap-2">
                    <button type="button" class="btn btn-sm btn-outline-secondary minute-btn" data-minute="0">:00</button>
                    <button type="button" class="btn btn-sm btn-outline-secondary minute-btn" data-minute="15">:15</button>
                    <button type="button" class="btn btn-sm btn-outline-secondary minute-btn" data-minute="30">:30</button>
                    <button type="button" class="btn btn-sm btn-outline-secondary minute-btn" data-minute="45">:45</button>
                </div>
            </div>
            <div class="d-flex gap-2">
                <button type="button" class="btn btn-sm btn-outline-secondary" onclick="this.closest('.simple-time-picker').querySelectorAll('.hour-btn, .minute-btn').forEach(b => b.classList.remove('btn-primary')); this.closest('.simple-time-picker').querySelectorAll('.hour-btn, .minute-btn').forEach(b => b.classList.add('btn-outline-secondary'))">Limpar</button>
                <button type="button" class="btn btn-sm btn-primary" onclick="this.closest('.simple-time-picker').style.display='none'">Fechar</button>
            </div>
        `;
        
        document.body.appendChild(this.picker);
        
        // Event listeners
        this.picker.querySelectorAll('.hour-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                this.picker.querySelectorAll('.hour-btn').forEach(b => {
                    b.classList.remove('btn-primary');
                    b.classList.add('btn-outline-secondary');
                });
                btn.classList.remove('btn-outline-secondary');
                btn.classList.add('btn-primary');
                this.selectedHour = parseInt(btn.dataset.hour);
                this.updateInput();
            });
        });
        
        this.picker.querySelectorAll('.minute-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                this.picker.querySelectorAll('.minute-btn').forEach(b => {
                    b.classList.remove('btn-primary');
                    b.classList.add('btn-outline-secondary');
                });
                btn.classList.remove('btn-outline-secondary');
                btn.classList.add('btn-primary');
                this.selectedMinute = parseInt(btn.dataset.minute);
                this.updateInput();
            });
        });
    }

    attachEvents() {
        this.input.addEventListener('click', (e) => {
            e.preventDefault();
            this.open();
        });

        document.addEventListener('click', (e) => {
            if (!this.picker.contains(e.target) && e.target !== this.input) {
                this.picker.style.display = 'none';
            }
        });
    }

    open() {
        const rect = this.input.getBoundingClientRect();
        this.picker.style.top = (rect.bottom + window.scrollY + 5) + 'px';
        this.picker.style.left = rect.left + 'px';
        this.picker.style.display = 'block';
    }

    updateInput() {
        if (this.selectedHour !== null && this.selectedMinute !== null) {
            const timeStr = `${this.selectedHour.toString().padStart(2, '0')}:${this.selectedMinute.toString().padStart(2, '0')}`;
            this.input.value = timeStr;
            this.input.dispatchEvent(new Event('change'));
        }
    }
}

