// Inicialização
document.addEventListener('DOMContentLoaded', function() {
    const today = new Date().toISOString().split('T')[0];
    document.getElementById('modal_data').value = today;
    
    // Resetar formulário quando abrir modal para novo lançamento
    document.querySelectorAll('[data-bs-target="#newLancamentoModal"]').forEach(btn => {
        btn.addEventListener('click', function() {
            resetFormToNew();
        });
    });
    
    // Inicializar time pickers quando o modal abrir
    const modal = document.getElementById('newLancamentoModal');
    if (modal) {
        modal.addEventListener('shown.bs.modal', function() {
            new SimpleTimePicker('modal_hora_inicio');
            new SimpleTimePicker('modal_hora_fim');
        });
    }
    
    // Inicializar estatísticas
    filtrarPorData();
});

function resetFormToNew() {
    document.getElementById('newLancamentoForm').action = '/novo-lancamento';
    document.getElementById('modal_data').readOnly = false;
    document.getElementById('modal_data').style.backgroundColor = '';
    document.getElementById('modal_data').style.fontWeight = '';
    document.querySelector('#newLancamentoModal .modal-title').innerHTML = '<i class="bi bi-plus-circle me-2"></i>Novo Lançamento';
    document.querySelector('#newLancamentoModal button[type="submit"]').innerHTML = '<i class="bi bi-check-circle me-1"></i>Salvar Lançamento';
    clearModalForm();
}

// Funções de edição e exclusão
function openEditModal(lancamentoId) {
    const editBtn = document.querySelector(`button[data-id="${lancamentoId}"]`);
    
    if (editBtn) {
        const data = editBtn.dataset.data;
        const inicio = editBtn.dataset.inicio;
        const fim = editBtn.dataset.fim;
        const atividadeId = editBtn.dataset.atividade;
        const observacao = editBtn.dataset.observacao || '';
        
        // Usar formato ISO (YYYY-MM-DD) para o input date
        document.getElementById('modal_data').value = data;
        document.getElementById('modal_hora_inicio').value = inicio;
        document.getElementById('modal_hora_fim').value = fim;
        document.getElementById('modal_atividade_id').value = atividadeId;
        document.getElementById('modal_observacao').value = observacao;
        
        document.getElementById('modal_data').readOnly = true;
        document.getElementById('modal_data').style.backgroundColor = '#f8f9fa';
        document.getElementById('modal_data').style.fontWeight = '500';
        
        document.getElementById('newLancamentoForm').action = `/editar-lancamento/${lancamentoId}`;
        document.querySelector('#newLancamentoModal .modal-title').innerHTML = '<i class="bi bi-pencil me-2"></i>Editar Lançamento';
        document.querySelector('#newLancamentoModal button[type="submit"]').innerHTML = '<i class="bi bi-check-circle me-1"></i>Atualizar Lançamento';
        
        const modal = new bootstrap.Modal(document.getElementById('newLancamentoModal'));
        modal.show();
        
        setTimeout(() => {
            new SimpleTimePicker('modal_hora_inicio');
            new SimpleTimePicker('modal_hora_fim');
        }, 100);
    }
}

let deleteLancamentoId = null;

function deleteLancamento(lancamentoId) {
    deleteLancamentoId = lancamentoId;
    const modal = new bootstrap.Modal(document.getElementById('deleteConfirmModal'));
    modal.show();
}

document.getElementById('confirmDeleteBtn')?.addEventListener('click', function() {
    if (deleteLancamentoId) {
        fetch(`/excluir-lancamento/${deleteLancamentoId}`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            }
        })
        .then(response => {
            if (response.ok) {
                const row = document.querySelector(`button[data-id="${deleteLancamentoId}"]`).closest('tr');
                row.remove();
                
                showNotification('Lançamento excluído com sucesso!', 'success');
                filtrarPorData();
                
                const modal = bootstrap.Modal.getInstance(document.getElementById('deleteConfirmModal'));
                modal.hide();
            } else {
                throw new Error('Erro ao excluir lançamento');
            }
        })
        .catch(error => {
            console.error('Erro:', error);
            alert('Erro ao excluir lançamento');
        });
    }
});

function showNotification(message, type = 'info') {
    const notification = document.createElement('div');
    notification.className = `alert alert-${type === 'success' ? 'success' : type === 'error' ? 'danger' : 'info'} alert-dismissible fade show position-fixed`;
    notification.style.cssText = 'top: 20px; right: 20px; z-index: 9999; min-width: 300px;';
    notification.innerHTML = `
        <div class="d-flex align-items-center">
            <i class="bi ${type === 'success' ? 'bi-check-circle' : type === 'error' ? 'bi-exclamation-triangle' : 'bi-info-circle'} me-2"></i>
            <div>${message}</div>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    `;
    
    document.body.appendChild(notification);
    
    setTimeout(() => {
        notification.remove();
    }, 5000);
}

// Bootstrap validation
(function () {
    'use strict';
    var forms = document.querySelectorAll('.needs-validation');
    Array.prototype.slice.call(forms).forEach(function (form) {
        form.addEventListener('submit', function (event) {
            if (!form.checkValidity()) {
                event.preventDefault();
                event.stopPropagation();
            } else {
                // Validar sobreposição de horários
                // Extrair ID do lançamento se for edição (action contém /editar-lancamento/)
                const formAction = form.getAttribute('action') || '';
                let lancamentoIdAtual = null;
                const match = formAction.match(/\/editar-lancamento\/(\d+)/);
                if (match) {
                    lancamentoIdAtual = match[1];
                }
                
                const validacao = validarSobreposicaoHorarios(lancamentoIdAtual);
                if (!validacao.valido) {
                    event.preventDefault();
                    event.stopPropagation();
                    alert(validacao.mensagem);
                    return;
                }
            }
            form.classList.add('was-validated');
        }, false);
    });
})();

// Função para converter horas decimais para formato Xh Ym
function formatHoursToHM(decimalHours) {
    const hours = Math.floor(decimalHours);
    const minutes = Math.round((decimalHours - hours) * 60);
    return `${hours}h ${minutes}m`;
}
