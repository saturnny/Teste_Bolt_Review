<%- include('../header_bootstrap', {title: 'Lançamentos da Equipe - ' + user.nome}) %>

<div class="topbar">
    <div class="topbar-title">
        <h1 style="font-weight: 700; color: #333;">Lançamentos da Equipe</h1>
        <p style="color: #666;">Visualize e gerencie os lançamentos de todos os usuários</p>
    </div>
</div>

<!-- Filtros -->
<div class="card mb-4" style="border: none; box-shadow: 0 4px 15px rgba(0,0,0,0.05); border-radius: 12px;">
    <div class="card-body p-4">
        <h5 class="card-title mb-4" style="font-weight: 700; color: #333; display: flex; align-items: center; gap: 10px;">
            <i class="bi bi-funnel" style="font-size: 1.2rem;"></i>
            Filtros
        </h5>
        <form method="get" class="row g-3">
            <div class="col-md-4">
                <label for="user_id" class="form-label">Usuário:</label>
                <select id="user_id" name="user_id" class="form-select">
                    <option value="">Todos os usuários</option>
                    <% if (typeof usuarios !== 'undefined') { %>
                        <% usuarios.forEach(function(usuario) { %>
                    <option value="<%= usuario.id %>" <%= (typeof filtro_user_id !== 'undefined' && filtro_user_id == usuario.id) ? 'selected' : '' %>>
                        <%= usuario.nome %>
                    </option>
                        <% }); %>
                    <% } %>
                </select>
            </div>

            <div class="col-md-4">
                <label for="data" class="form-label">Data:</label>
                <input type="date" id="data" name="data" class="form-control" value="<%= (typeof filtro_data !== 'undefined') ? filtro_data : '' %>">
            </div>

            <div class="col-md-4">
                <label class="form-label">&nbsp;</label>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary" style="background-color: #A00000; border-color: #A00000;">
                        <i class="bi bi-search me-1"></i>
                        Filtrar
                    </button>
                    <a href="/admin/lancamentos" class="btn btn-outline-secondary">
                        <i class="bi bi-x-circle me-1"></i>
                        Limpar
                    </a>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- Estatísticas -->
<% if (typeof lancamentos !== 'undefined' && lancamentos.length > 0) { %>
<div class="stats-grid mb-4">
    <div class="stat-card primary">
        <div class="stat-icon">
            <i class="bi bi-clipboard-data"></i>
        </div>
        <div class="stat-content">
            <div class="stat-value"><%= lancamentos.length %></div>
            <div class="stat-label">Total de Lançamentos</div>
        </div>
    </div>
    
    <div class="stat-card success">
        <div class="stat-icon">
            <i class="bi bi-clock"></i>
        </div>
        <div class="stat-content">
            <div class="stat-value"><%= parseFloat(lancamentos.reduce((acc, curr) => acc + (parseFloat(curr.horas_trabalhadas) || 0), 0)).toFixed(1) %>h</div>
            <div class="stat-label">Total de Horas</div>
        </div>
    </div>
    
    <div class="stat-card info">
        <div class="stat-icon">
            <i class="bi bi-people"></i>
        </div>
        <div class="stat-content">
            <div class="stat-value"><%= typeof usuarios !== 'undefined' ? usuarios.length : 0 %></div>
            <div class="stat-label">Usuários Ativos</div>
        </div>
    </div>
</div>
<% } %>

<!-- Tabela de Lançamentos -->
<div class="card" style="border: none; box-shadow: 0 4px 15px rgba(0,0,0,0.05); border-radius: 12px; overflow: hidden;">
    <div class="card-header bg-white border-0 p-4 pb-0">
        <h5 class="card-title mb-1" style="font-weight: 700; color: #333; display: flex; align-items: center; gap: 10px;">
            <i class="bi bi-clock-history" style="font-size: 1.2rem;"></i>
            Lançamentos Encontrados
        </h5>
        <p class="text-muted small"><%= (typeof lancamentos !== 'undefined' ? lancamentos.length : 0) %> lançamentos encontrados</p>
    </div>

    <% if (typeof lancamentos !== 'undefined' && lancamentos.length > 0) { %>
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th><i class="bi bi-person me-1"></i>Usuário</th>
                    <th><i class="bi bi-calendar3 me-1"></i>Data</th>
                    <th><i class="bi bi-clock me-1"></i>Início</th>
                    <th><i class="bi bi-clock-fill me-1"></i>Fim</th>
                    <th><i class="bi bi-list-task me-1"></i>Atividade</th>
                    <th><i class="bi bi-chat-text me-1"></i>Observação</th>
                    <th><i class="bi bi-hourglass-split me-1"></i>Horas</th>
                    <th style="width: 120px;"><i class="bi bi-gear me-1"></i>Ações</th>
                </tr>
            </thead>
            <tbody>
                <% lancamentos.forEach(function(lancamento) { %>
                <tr>
                    <td>
                        <div class="d-flex align-items-center gap-2">
                            <div class="user-avatar" style="background-color: #A00000; color: white; width: 32px; height: 32px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: bold;">
                                <%= (lancamento.User) ? lancamento.User.nome.substring(0, 2).toUpperCase() : '??' %>
                            </div>
                            <span><%= (lancamento.User) ? lancamento.User.nome : (lancamento.usuario ? lancamento.usuario.nome : '-') %></span>
                        </div>
                    </td>
                    <td>
                        <span class="badge bg-light text-dark"><%= (lancamento.data) ? new Date(lancamento.data).toLocaleDateString('pt-BR') : '-' %></span>
                    </td>
                    <td><%= (lancamento.hora_inicio) ? lancamento.hora_inicio : '-' %></td>
                    <td><%= (lancamento.hora_fim) ? lancamento.hora_fim : '-' %></td>
                    <td>
                        <div class="d-flex align-items-center gap-2">
                            <span class="badge bg-primary"><%= (lancamento.Atividade) ? lancamento.Atividade.nome : (lancamento.atividade ? lancamento.atividade.nome : '-') %></span>
                            <small class="text-muted"><%= (lancamento.Atividade && lancamento.Atividade.Categoria) ? lancamento.Atividade.Categoria.nome : (lancamento.atividade && lancamento.atividade.categoria ? lancamento.atividade.categoria.nome : '') %></small>
                        </div>
                    </td>
                    <td>
                        <small class="text-muted"><%= (lancamento.descricao || '-') %></small>
                    </td>
                    <td>
                        <span class="badge bg-success"><%= parseFloat(lancamento.horas_trabalhadas || 0).toFixed(1) %>h</span>
                    </td>
                    <td>
                        <div class="btn-group" role="group">
                            <button class="btn btn-sm btn-outline-primary" 
                                   data-bs-toggle="tooltip" 
                                   data-bs-placement="top" 
                                   title="Editar lançamento"
                                   onclick="alert('Funcionalidade de edição será implementada')">
                                <i class="bi bi-pencil"></i>
                            </button>
                            <button class="btn btn-sm btn-outline-danger" 
                                    data-bs-toggle="tooltip" 
                                    data-bs-placement="top" 
                                    title="Excluir lançamento"
                                    onclick="confirmDelete('<%= lancamento.id %>')">
                                <i class="bi bi-trash"></i>
                            </button>
                        </div>
                    </td>
                </tr>
                <% }); %>
            </tbody>
        </table>
    </div>
    
    <% } else { %>
    <div class="card-body text-center py-5">
        <div class="empty-state">
            <div class="empty-state-icon">
                <i class="bi bi-clipboard-x" style="font-size: 48px; color: var(--bs-secondary);"></i>
            </div>
            <div class="empty-state-title">Nenhum lançamento encontrado</div>
            <div class="empty-state-description">
                Não há lançamentos com os filtros selecionados.
            </div>
        </div>
    </div>
    <% } %>
</div>

<%- include('../footer_bootstrap') %>

<style>
.stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 20px;
    margin-bottom: 30px;
}

.stat-card {
    background: white;
    border-radius: 20px;
    padding: 24px;
    box-shadow: 0 4px 15px rgba(0,0,0,0.05);
    border: 1px solid #f0f0f0;
    transition: transform 0.3s ease;
    display: flex;
    align-items: center;
    gap: 20px;
}

.stat-icon {
    width: 60px;
    height: 60px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.8rem;
    color: white;
    flex-shrink: 0;
}

.stat-card.primary .stat-icon {
    background: #A00000;
}

.stat-card.success .stat-icon {
    background: #16A34A;
}

.stat-card.info .stat-icon {
    background: #2563EB;
}

.stat-content {
    flex: 1;
}

.stat-value {
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--bs-dark);
    line-height: 1;
    margin-bottom: 4px;
}

.stat-label {
    font-size: 0.9rem;
    color: var(--bs-secondary);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.user-avatar {
    font-size: 12px;
    font-weight: bold;
}

.table thead th {
    background-color: #f1f4f9;
    color: #555;
    font-weight: 600;
    text-transform: none;
    font-size: 0.85rem;
    padding: 12px 16px;
    border-bottom: 2px solid #eef2f7;
}

.table tbody td {
    padding: 14px 16px;
    vertical-align: middle;
}

.badge {
    padding: 6px 12px;
    font-weight: 500;
    border-radius: 6px;
}

.card {
    border: none;
    box-shadow: 0 4px 15px rgba(0,0,0,0.05);
    border-radius: 12px;
    overflow: hidden;
}

.empty-state {
    padding: 2rem;
}

.empty-state-icon {
    margin-bottom: 1rem;
}

.empty-state-title {
    font-size: 1.2rem;
    font-weight: 600;
    color: #333;
    margin-bottom: 0.5rem;
}

.empty-state-description {
    color: #666;
}
</style>

<script>
function confirmDelete(id) {
    if (confirm('Tem certeza que deseja excluir este lançamento?')) {
        fetch(`/admin/lancamentos/${id}/excluir`, {
            method: 'POST'
        })
        .then(response => response.ok ? window.location.reload() : alert('Erro ao excluir'))
        .catch(error => alert('Erro ao excluir'));
    }
}

// Initialize tooltips
var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'))
var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
    return new bootstrap.Tooltip(tooltipTriggerEl)
});
</script>
