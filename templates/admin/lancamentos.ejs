<%- include('../header_bootstrap', {title: 'Lançamentos da Equipe - ' + user.nome}) %>
<div class="card">
    <div class="card-header">
        <h2>Lançamentos da Equipe</h2>
    </div>

    <!-- Filtros -->
    <form method="get" class="filters">
        <div class="form-group">
            <label for="user_id">Usuário:</label>
            <select id="user_id" name="user_id" class="form-control">
                <option value="">Todos os usuários</option>
                <% if (typeof usuarios !== 'undefined') { %>
                    <% usuarios.forEach(function(usuario) { %>
                <option value="<%= usuario.id %>" <%= (typeof filtro_user_id !== 'undefined' && filtro_user_id == usuario.id) ? 'selected' : '' %>>
                    <%= usuario.nome %>
                </option>
                    <% }); %>
                <% } %>
            </select>
        </div>

        <div class="form-group">
            <label for="data">Data:</label>
            <input type="date" id="data" name="data" class="form-control" value="<%= (typeof filtro_data !== 'undefined') ? filtro_data : '' %>">
        </div>

        <div class="form-group" style="display: flex; align-items: flex-end;">
            <button type="submit" class="btn btn-primary">Filtrar</button>
            <a href="/admin/lancamentos" class="btn btn-secondary" style="margin-left: 0.5rem;">Limpar</a>
        </div>
    </form>

    <% if (typeof lancamentos !== 'undefined' && lancamentos.length > 0) { %>
    <table class="table">
        <thead>
            <tr>
                <th>Usuário</th>
                <th>Data</th>
                <th>Início</th>
                <th>Fim</th>
                <th>Atividade</th>
                <th>Observação</th>
                <th>Horas</th>
            </tr>
        </thead>
        <tbody>
            <% lancamentos.forEach(function(lancamento) { %>
            <tr>
                <td><%= (lancamento.Usuario) ? lancamento.Usuario.nome : (lancamento.usuario ? lancamento.usuario.nome : '-') %></td>
                <td><%= (lancamento.data) ? new Date(lancamento.data).toLocaleDateString('pt-BR') : '-' %></td>
                <td><%= (lancamento.hora_inicio) ? lancamento.hora_inicio : '-' %></td>
                <td><%= (lancamento.hora_fim) ? lancamento.hora_fim : '-' %></td>
                <td><%= (lancamento.Atividade) ? lancamento.Atividade.nome : (lancamento.atividade ? lancamento.atividade.nome : '-') %></td>
                <td><%= (lancamento.descricao || '-') %></td>
                <td><%= (lancamento.horas_trabalhadas || 0).toFixed(1) %>h</td>
            </tr>
            <% }); %>
        </tbody>
    </table>
    
    <div style="margin-top: 2rem; padding: 1rem; background-color: #f8f9fa; border-radius: 5px;">
        <h4>Resumo</h4>
        <p><strong>Total de Lançamentos:</strong> <%= lancamentos.length %></p>
        <p><strong>Total de Horas:</strong> <%= lancamentos.reduce((acc, curr) => acc + (parseFloat(curr.horas_trabalhadas) || 0), 0).toFixed(1) %>h</p>
    </div>
    <% } else { %>
    <div style="text-align: center; padding: 2rem; color: #666;">
        <p>Nenhum lançamento encontrado com os filtros selecionados.</p>
    </div>
    <% } %>
</div>
<%- include('../footer_bootstrap') %>
