<%- include('../header_bootstrap', {title: 'Gerenciar Usuários - ' + user.nome}) %>

<!-- DEBUG: <%= typeof usuarios !== 'undefined' ? usuarios.length : 'undefined' %> usuários -->

<div class="topbar">
    <div class="topbar-title">
        <h1 style="font-weight: 700; color: #333;">Gerenciamento de Usuários</h1>
        <p style="color: #666;">Administre os usuários do sistema</p>
    </div>
    <div class="d-flex gap-2">
        <button class="btn" style="background-color: #A00000; color: white; border-radius: 8px; font-weight: 500; padding: 10px 20px;" data-bs-toggle="modal" data-bs-target="#userModal">
            <i class="bi bi-person-plus me-1"></i>
            Novo Usuário
        </button>
    </div>
</div>
<!-- Filters -->
<div class="card mb-4" style="border: none; box-shadow: 0 4px 15px rgba(0,0,0,0.05); border-radius: 12px;">
    <div class="card-body p-4">
        <h5 class="card-title mb-4" style="font-weight: 700; color: #333; display: flex; align-items: center; gap: 10px;">
            <i class="bi bi-funnel" style="font-size: 1.2rem;"></i>
            Filtros
        </h5>
        <div class="row g-3">
            <div class="col-md-4">
                <input type="text" class="form-control" style="border-radius: 8px; padding: 10px 15px; border: 1px solid #ddd;" placeholder="Buscar por nome ou email" id="searchInput">
            </div>
            <div class="col-md-4">
                <select class="form-select" style="border-radius: 8px; padding: 10px 15px; border: 1px solid #ddd;" id="typeFilter">
                    <option value="">Todos os tipos</option>
                    <option value="Admin">Administrador</option>
                    <option value="Usuario">Usuário</option>
                </select>
            </div>
            <div class="col-md-2">
                <button class="btn w-100" style="background-color: #f8f9fa; color: #666; border: 1px solid #ddd; border-radius: 8px; padding: 10px;" onclick="clearFilters()">
                    <i class="bi bi-x-circle me-1"></i>
                    Limpar
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Users Table -->
<div class="card" style="border: none; box-shadow: 0 4px 15px rgba(0,0,0,0.05); border-radius: 12px; overflow: hidden;">
    <div class="card-header bg-white border-0 p-4 pb-0">
        <h5 class="card-title mb-1" style="font-weight: 700; color: #333; display: flex; align-items: center; gap: 10px;">
            <i class="bi bi-people" style="font-size: 1.2rem;"></i>
            Usuários Cadastrados
        </h5>
        <p class="text-muted small"><%= (typeof usuarios !== 'undefined' ? usuarios.length : 0) %> usuários encontrados</p>
    </div>

    <% if (typeof usuarios !== 'undefined' && usuarios.length > 0) { %>
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0" id="usersTable">
            <thead style="background-color: #f1f4f9;">
                <tr>
                    <th style="padding: 15px 20px; font-weight: 600; color: #555; border: none;"><i class="bi bi-person me-1"></i>Usuário</th>
                    <th style="padding: 15px 20px; font-weight: 600; color: #555; border: none;"><i class="bi bi-envelope me-1"></i>Email</th>
                    <th style="padding: 15px 20px; font-weight: 600; color: #555; border: none;"><i class="bi bi-briefcase me-1"></i>Gestão</th>
                    <th style="padding: 15px 20px; font-weight: 600; color: #555; border: none;"><i class="bi bi-geo-alt me-1"></i>Área</th>
                    <th style="padding: 15px 20px; font-weight: 600; color: #555; border: none;"><i class="bi bi-people me-1"></i>Equipe</th>
                    <th style="padding: 15px 20px; font-weight: 600; color: #555; border: none;"><i class="bi bi-award me-1"></i>Especialidade</th>
                    <th style="padding: 15px 20px; font-weight: 600; color: #555; border: none;"><i class="bi bi-shield me-1"></i>Tipo</th>
                    <th style="padding: 15px 20px; font-weight: 600; color: #555; border: none; width: 150px;"><i class="bi bi-gear me-1"></i>Ações</th>
                </tr>
            </thead>
            <tbody>
                <% usuarios.forEach(function(usuario) { %>
                <tr class="user-row" data-name="<%= usuario.nome.toLowerCase() %>" data-email="<%= usuario.email.toLowerCase() %>" 
                    data-type="<%= usuario.tipo_usuario %>">
                    <td style="padding: 15px 20px;">
                        <div class="d-flex align-items-center gap-3">
                            <div class="avatar avatar-sm" style="background-color: #8b0000; color: white; width: 35px; height: 35px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 600;"><%= usuario.nome.substring(0, 2).toUpperCase() %></div>
                            <div>
                                <div class="fw-bold" style="color: #333;"><%= usuario.nome %></div>
                                <small class="text-muted">ID: <%= usuario.id %></small>
                            </div>
                        </div>
                    </td>
                    <td><%= usuario.email %></td>
                    <td><%= usuario.gestao || '-' %></td>
                    <td><%= usuario.area || '-' %></td>
                    <td><%= usuario.equipe || '-' %></td>
                    <td><%= usuario.especialidade || '-' %></td>
                    <td style="padding: 15px 20px;">
                        <span class="badge" style="background-color: #94a3b8; color: white; font-weight: 500; border-radius: 20px; padding: 5px 12px; font-size: 0.75rem;">
                            <%= usuario.tipo_usuario %>
                        </span>
                    </td>
                    <td style="padding: 15px 20px;">
                        <div class="d-flex gap-2">
                            <button class="btn btn-sm" style="border: 1px solid #eca9a9; color: #dc3545; background: white; width: 32px; height: 32px; padding: 0; display: flex; align-items: center; justify-content: center;"
                                    onclick="editUser(<%= usuario.id %>)"
                                    data-bs-toggle="tooltip" 
                                    title="Editar usuário">
                                <i class="bi bi-pencil"></i>
                            </button>
                            <% if (usuario.id !== user.id) { %>
                            <button class="btn btn-sm" style="border: 1px solid #eca9a9; color: #dc3545; background: white; width: 32px; height: 32px; padding: 0; display: flex; align-items: center; justify-content: center;"
                                    onclick="deleteUser(<%= usuario.id %>)"
                                    data-bs-toggle="tooltip" 
                                    title="Excluir usuário">
                                <i class="bi bi-trash"></i>
                            </button>
                            <% } %>
                        </div>
                    </td>
                </tr>
                <% }); %>
            </tbody>
        </table>
    </div>
    
    <div class="card-footer">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
            <div>
                <span class="badge bg-secondary me-2">
                    <i class="bi bi-people me-1"></i>
                    <%= (typeof usuarios !== 'undefined' ? usuarios.filter(u => u.tipo_usuario === 'Admin').length : 0) %> administradores
                </span>
                <span class="badge bg-secondary me-2">
                    <i class="bi bi-person me-1"></i>
                    <%= (typeof usuarios !== 'undefined' ? usuarios.filter(u => u.tipo_usuario !== 'Admin').length : 0) %> usuários comuns
                </span>
                <span class="badge bg-success">
                    <i class="bi bi-people-fill me-1"></i>
                    <%= (typeof usuarios !== 'undefined' ? usuarios.length : 0) %> total
                </span>
            </div>
            <div>
                <button class="btn btn-outline-secondary" onclick="exportUsers()">
                    <i class="bi bi-download me-1"></i>
                    Exportar
                </button>
            </div>
        </div>
    </div>
    <% } else { %>
    <div class="card-body text-center py-5">
        <div class="empty-state">
            <div class="empty-state-icon">
                <i class="bi bi-people" style="font-size: 48px; color: var(--bs-secondary);"></i>
            </div>
            <div class="empty-state-title">Nenhum usuário encontrado</div>
            <div class="empty-state-description">
                Comece adicionando um novo usuário ao sistema.
            </div>
            <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#userModal">
                <i class="bi bi-person-plus me-1"></i>
                Adicionar Primeiro Usuário
            </button>
        </div>
    </div>
    <% } %>
</div>

<!-- User Modal -->
<div class="modal fade" id="userModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="bi bi-person-plus me-2"></i>
                    <span id="userModalTitle">Novo Usuário</span>
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            
            <form id="userForm" method="post" action="/admin/usuarios">
                <div class="modal-body">
                    <input type="hidden" id="userId" name="user_id">
                    
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label for="nome" class="form-label">Nome Completo *</label>
                            <input type="text" id="nome" name="nome" class="form-control" required>
                        </div>
                        
                        <div class="col-md-6">
                            <label for="email" class="form-label">Email *</label>
                            <input type="email" id="email" name="email" class="form-control" required>
                        </div>
                    </div>
                    
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label for="senha" class="form-label" id="senhaLabel">Senha *</label>
                            <input type="password" id="senha" name="senha" class="form-control">
                        </div>
                        
                        <div class="col-md-6">
                            <label for="tipo_usuario" class="form-label">Tipo de Usuário *</label>
                            <select id="tipo_usuario" name="tipo_usuario" class="form-select" required>
                                <option value="Usuário">Usuário</option>
                                <option value="Admin">Administrador</option>
                            </select>
                        </div>
                    </div>
                    
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label for="gestao" class="form-label">Gestão</label>
                            <input type="text" id="gestao" name="gestao" class="form-control">
                        </div>
                        
                        <div class="col-md-6">
                            <label for="area" class="form-label">Área</label>
                            <input type="text" id="area" name="area" class="form-control">
                        </div>
                    </div>
                    
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label for="equipe" class="form-label">Equipe</label>
                            <input type="text" id="equipe" name="equipe" class="form-control">
                        </div>
                        
                        <div class="col-md-6">
                            <label for="especialidade" class="form-label">Especialidade</label>
                            <input type="text" id="especialidade" name="especialidade" class="form-control">
                        </div>
                    </div>
                </div>
                
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                        <i class="bi bi-x-circle me-1"></i>
                        Cancelar
                    </button>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-circle me-1"></i>
                        Salvar
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
<script>
    let editingUserId = null;

    function showUserModal(userId = null) {
        const modal = new bootstrap.Modal(document.getElementById('userModal'));
        const form = document.getElementById('userForm');
        const title = document.getElementById('userModalTitle');
        const senhaField = document.getElementById('senha');
        const senhaLabel = document.getElementById('senhaLabel');
        
        if (userId) {
            // Edit mode
            title.textContent = 'Editar Usuário';
            senhaLabel.textContent = 'Nova Senha (deixe em branco para manter)';
            senhaField.required = false;
            editingUserId = userId;
            // Here you would load user data via API
            console.log('Edit user:', userId);
        } else {
            // Create mode
            title.textContent = 'Novo Usuário';
            senhaLabel.textContent = 'Senha *';
            senhaField.required = true;
            form.reset();
            editingUserId = null;
        }
        
        modal.show();
    }

    function editUser(userId) {
        showUserModal(userId);
    }

    function toggleUserStatus(userId, currentStatus) {
        const action = currentStatus ? 'desativar' : 'ativar';
        if (confirm(`Tem certeza que deseja ${action} este usuário?`)) {
            // In a real implementation, make API call
            showNotification(`Usuário ${action} com sucesso!`, 'success');
            setTimeout(() => location.reload(), 1500);
        }
    }

    function deleteUser(userId) {
        if (confirm('Tem certeza que deseja excluir este usuário? Esta ação não pode ser desfeita.')) {
            // In a real implementation, make API call
            showNotification('Usuário excluído com sucesso!', 'warning');
            setTimeout(() => location.reload(), 1500);
        }
    }

    function exportUsers() {
        showInfo('Funcionalidade de exportação será implementada em breve', 'Exportar');
    }

    function clearFilters() {
        document.getElementById('searchInput').value = '';
        document.getElementById('typeFilter').value = '';
        document.getElementById('statusFilter').value = '';
        filterUsers();
    }

    function filterUsers() {
        const searchTerm = document.getElementById('searchInput').value.toLowerCase();
        const typeValue = document.getElementById('typeFilter').value;
        const statusValue = document.getElementById('statusFilter').value;
        
        const rows = document.querySelectorAll('#usersTable .user-row');
        
        rows.forEach(row => {
            const text = row.textContent.toLowerCase();
            const type = row.dataset.type;
            const status = row.dataset.status;
            
            const matchesSearch = text.includes(searchTerm);
            const matchesType = !typeValue || type.includes(typeValue);
            const matchesStatus = !statusValue || status.includes(statusValue);
            
            row.style.display = matchesSearch && matchesType && matchesStatus ? '' : 'none';
        });
    }

    // Event listeners
    document.getElementById('searchInput')?.addEventListener('input', filterUsers);
    document.getElementById('typeFilter')?.addEventListener('change', filterUsers);
    document.getElementById('statusFilter')?.addEventListener('change', filterUsers);

    // Initialize tooltips
    document.addEventListener('DOMContentLoaded', function() {
        const tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
        const tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
            return new bootstrap.Tooltip(tooltipTriggerEl);
        });
    });
</script>
<%- include('../footer_bootstrap') %>
